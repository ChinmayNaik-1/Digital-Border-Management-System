# Flask
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=5000

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=border_db
POSTGRES_USER=border_user
POSTGRES_PASSWORD=border_pass

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=faces
MINIO_SECURE=false

# App
APP_LOG_LEVEL=INFO
